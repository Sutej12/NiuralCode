# OpenAI API Key (for AI screening, offer letter generation, etc.)
OPENAI_API_KEY=your-openai-api-key-here

# Gmail SMTP (for sending emails)
EMAIL_HOST_USER=your-gmail@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password-here

# Google Calendar API
GOOGLE_CALENDAR_CREDENTIALS_JSON=path/to/credentials.json
GOOGLE_CALENDAR_ID=primary

# Slack API
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_SIGNING_SECRET=your-slack-signing-secret
SLACK_TEAM_ID=your-slack-team-id
SLACK_HR_CHANNEL_ID=your-hr-channel-id

# Fireflies.ai (Notetaker)
FIREFLIES_API_KEY=your-fireflies-api-key-here

# Application Settings
AI_SCREENING_THRESHOLD=70
SITE_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000
